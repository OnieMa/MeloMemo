# Docker runtime env. Copy this file to .env.docker before running docker compose.

DATABASE_URL="file:/app/data/melomemo.db"
API_PORT=8787
APP_TIME_ZONE=Asia/Shanghai

# Optional: YouTube official API search. Without it, the server uses page scraping fallback.
YOUTUBE_API_KEY=
GOOGLE_API_KEY=
YOUTUBE_SEARCH_PROXY=

# Optional: iFlytek TTS. Word pronunciation still has browser fallback when these are empty.
XF_APPID=
XF_API_KEY=
XF_API_SECRET=
XF_TTS_EN_US_VOICE=catherine
XF_TTS_EN_GB_VOICE=mary
XF_TTS_SPEED=42
XF_TTS_VOLUME=85
XF_TTS_PITCH=50

# Optional: WeChat login.
WECHAT_APP_ID=
WECHAT_REDIRECT_URI=
