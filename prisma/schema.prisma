generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model VocabularyWord {
  id         String   @id @default(cuid())
  word       String   @unique
  phonetic   String?
  meaning    String
  example    String?
  sourceSong String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
